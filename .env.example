# Core database (required everywhere)
DATABASE_URL="postgresql://postgres:password@localhost:5432/animeroom"

# Clerk authentication (required everywhere)
CLERK_SECRET_KEY="clerk_secret_placeholder"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="clerk_publishable_placeholder"

# Canonical application URL (required everywhere)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upstash Redis rate limiting and realtime (required everywhere)
UPSTASH_REDIS_REST_URL="https://redis.example.com"
UPSTASH_REDIS_REST_TOKEN="redis_token_placeholder"

# Cloudflare R2 storage (required everywhere)
R2_Access_Key_ID="r2_access_placeholder"
R2_Secret_Access_Key="r2_secret_placeholder"
R2_BUCKET_NAME="animeroom-local"
R2_PUBLIC_BASE_URL="https://cdn.example.com"

# AI providers (required everywhere)
REPLICATE_IMAGE_API_TOKEN="replicate_token_placeholder"
GOOGLE_GENERATIVE_AI_API_KEY="google_key_placeholder"

# Stripe payments (required everywhere; use test-mode values locally/CI)
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_STARTER_PACK_PRICE_ID="price_placeholder"

# Admin Clerk user ID (required everywhere)
ADMIN_USER="user_placeholder"

# Remotion Lambda export (required everywhere)
REMOTION_FUNCTION_NAME="remotion-render-placeholder"
REMOTION_SERVE_URL="https://remotion.example.com/site.zip"

# Inngest cloud authentication (required in production; optional locally)
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""

# Platform/control values (optional locally)
NODE_ENV="development"
VERCEL_URL=""
PORT="3000"
SKIP_ENV_VALIDATION=""
