{
  "name": "AnimeRoomT3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,mdx}\" \"*.{ts,js,mjs,json}\" README.md TECH-STACK.md WORKFLOW.md \"docs/**/*.md\" \".github/**/*.yml\" --cache",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,js,jsx,mdx}\" \"*.{ts,js,mjs,json}\" README.md TECH-STACK.md WORKFLOW.md \"docs/**/*.md\" \".github/**/*.yml\" --cache",
    "grok": "npx tsx src/lib/ai/grok.ts",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest run",
    "verify:launch": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "preview": "next build && next start",
    "start": "HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "studio": "remotion studio src/remotion/Root.tsx --config=src/remotion/remotion.config.ts",
    "typecheck": "tsc --noEmit",
    "inngest:dev": "pnpx inngest-cli@latest dev"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/xai": "^3.0.56",
    "@aws-sdk/client-s3": "3.1089.0",
    "@aws-sdk/lib-storage": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@clerk/nextjs": "^6.39.6",
    "@elevenlabs/elevenlabs-js": "^2.58.0",
    "@hookform/resolvers": "^5.2.2",
    "@remotion/bundler": "4.0.425",
    "@remotion/cli": "4.0.425",
    "@remotion/lambda": "4.0.425",
    "@remotion/lambda-client": "4.0.425",
    "@remotion/media-parser": "4.0.425",
    "@remotion/media-utils": "4.0.425",
    "@remotion/player": "4.0.425",
    "@remotion/tailwind-v4": "4.0.425",
    "@stripe/stripe-js": "^9.0.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@upstash/realtime": "^1.0.3",
    "@upstash/redis": "^1.36.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "add": "^2.0.6",
    "ai": "^6.0.86",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "get-audio-duration": "^4.0.1",
    "inngest": "^4.13.0",
    "lucide-react": "^0.575.0",
    "mediabunny": "^1.39.2",
    "next": "^15.5.20",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.4",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.71.2",
    "remotion": "4.0.425",
    "replicate": "^1.4.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^21.0.1",
    "superjson": "^2.2.1",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.3",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.5.20",
    "eslint-plugin-drizzle": "^0.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vitest": "^4.1.10"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "ws": "^8.21.1",
      "hono": "^4.12.30",
      "minimatch@3.1.2": "3.1.4",
      "serialize-javascript": "^7.0.3",
      "@hono/node-server": "^1.19.10",
      "express-rate-limit": "^8.2.2",
      "flatted": "^3.4.2",
